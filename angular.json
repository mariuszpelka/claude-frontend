{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "packages",
  "projects": {
    "angular": {
      "projectType": "library",
      "root": "packages/angular",
      "sourceRoot": "packages/angular/src",
      "prefix": "p4",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/storybook-stub",
            "index": "packages/angular/.storybook/index.html",
            "main": "packages/angular/.storybook/main-stub.ts",
            "tsConfig": "packages/angular/.storybook/tsconfig.json",
            "polyfills": [],
            "styles": ["packages/angular/.storybook/preview.css"]
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "browserTarget": "angular:build",
            "configDir": "packages/angular/.storybook",
            "compodoc": false,
            "port": 4402,
            "styles": ["packages/angular/.storybook/preview.css"]
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "browserTarget": "angular:build",
            "outputDir": "packages/angular/storybook-static",
            "configDir": "packages/angular/.storybook",
            "compodoc": false,
            "styles": ["packages/angular/.storybook/preview.css"]
          }
        }
      }
    }
  }
}
