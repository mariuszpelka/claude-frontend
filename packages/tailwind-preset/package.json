{
  "name": "@p4/crm-mvp-components-tailwind-preset",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@org/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./preset.css": "./dist/preset.css"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "tslib": "^2.3.0",
    "@p4/crm-mvp-components-tokens": "workspace:*"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "nx": {
    "targets": {
      "build": {
        "options": {
          "command": "tsc --build tsconfig.lib.json && node ./dist/scripts/generate-preset-css.js"
        }
      }
    }
  }
}
