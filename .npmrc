# Registry mapping for @p4 scope.
# TODO: replace placeholder URL with the internal Play npm registry once available.
#       Examples: Verdaccio (https://npm.play.pl/), Nexus (https://nexus.play.pl/repository/npm-internal/),
#                 GitHub Packages (https://npm.pkg.github.com/).
# Authentication is typically configured via an env var, e.g.:
#       //npm.play.pl/:_authToken=${PLAY_NPM_TOKEN}
@p4:registry=https://registry.npmjs.org/

# pnpm hardening / convenience for the monorepo
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
node-linker=isolated
confirm-modules-purge=false
